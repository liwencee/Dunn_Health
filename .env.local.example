# MongoDB Connection (required for appointment/contact API)
# Replace <username> and <password> with your actual MongoDB Atlas credentials
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dunnbehavioralhealth?retryWrites=true&w=majority

# Email SMTP (required to send appointment/contact emails)
# The info@ mailbox is a Titan Email account (via Hostinger), so the host is
# smtp.titan.email — NOT smtp.hostinger.com (that returns 535 auth failed).
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=465
EMAIL_USER=info@dunnbehavioralhealth.us
EMAIL_PASS=<your_titan_mailbox_password>

# App URL
NEXT_PUBLIC_SITE_URL=https://dunnbehavioralhealth.us
